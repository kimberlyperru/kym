# ============================
# KYM TRADING BOT - ENVIRONMENT
# ============================

# Server
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# MySQL Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=kym_trading
DB_USER=root
DB_PASSWORD=your_mysql_password

# JWT Secrets (use strong random strings)
JWT_SECRET=kym_jwt_secret_change_this_in_production_use_64_chars_minimum
JWT_REFRESH_SECRET=kym_refresh_secret_change_this_in_production_use_64_chars_minimum
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Encryption Key (32 chars for AES-256)
ENCRYPTION_KEY=kym_aes256_key_change_this_now_32

# IntaSend Payment
INTASEND_PUBLISHABLE_KEY=your_intasend_publishable_key
INTASEND_SECRET_KEY=your_intasend_secret_key
INTASEND_WEBHOOK_SECRET=your_intasend_webhook_secret
SUBSCRIPTION_PRICE_KSH=1

# Email (for OTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=Kym Trading Bot <noreply@kymbot.com>

# MT5 Bridge (Python microservice)
MT5_BRIDGE_URL=http://localhost:8000
MT5_BRIDGE_SECRET=kym_mt5_bridge_secret_key

# News API (free - newsapi.org)
NEWS_API_KEY=your_newsapi_key

# Admin
ADMIN_SECRET_PATH=kym-admin-x9z
ADMIN_EMAIL=admin@kymbot.com
ADMIN_PASSWORD=ChangeThisAdminPassword!

# Redis (optional - for session caching)
REDIS_URL=redis://localhost:6379

# Rate Limiting
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION=15
